#include <stdio.h>

int factorial(int n)
{
    if(n==1)
    {
        printf("1 = ");
        return 1;
    }
    printf("%d x ",n);
    return n * factorial(n - 1);
}
int main()
{
    int n;
    printf("Enter a number: ");
    scanf("%d", &n);
    printf("%d! = ",n);
    printf("%d", factorial(n));
    return 0;
}